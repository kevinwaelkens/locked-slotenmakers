# Copy to .env (gitignored) for local dev
# In production, set these in Vercel project → Settings → Environment Variables

# Resend API key — https://resend.com/api-keys
# Required for the /api/contact endpoint
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Google Analytics 4 — Measurement ID (G-xxxxxxxxxx). Optional: leeg = geen GA / geen cookiebanner.
# Zet ook op Vercel (Production + Preview) als variabele met prefix VITE_
VITE_GA_MEASUREMENT_ID=
